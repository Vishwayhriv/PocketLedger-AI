    <!-- Onboarding & Splash -->
    <string name="welcome_title">தனியுரிமைக்கு முதலிடம்</string>
    <string name="welcome_desc">திரை ஸ்கிராப்பிங் இல்லை. SMS வாசிப்பு இல்லை. உங்கள் வங்கி கணக்கு பாதுகாப்பானது. பாக்கெட் லெட்ஜர் உங்கள் பரிவர்த்தனை தரவு அனைத்தையும் உங்கள் சாதனத்தில் 100% ஆஃப்லைனில் செயலாக்குகிறது.</string>
    <string name="welcome_benefit1_title">சம்பள விவரக் கதைசொல்லல்</string>
    <string name="welcome_benefit1_desc">விரிதாள்களுக்குப் பதிலாக எளிய உரையாடல் வடிவிலான சுருக்கங்கள்.</string>
    <string name="welcome_benefit2_title">மறைமுக சந்தா வேட்டைக்காரன்</string>
    <string name="welcome_benefit2_desc">பின்னணியில் நடக்கும் வீண் செலவுகளைத் துல்லியமாகக் கண்டறிதல்.</string>
    <string name="welcome_benefit3_title">நுண் கசிவு கண்டறிவான்</string>
    <string name="welcome_benefit3_desc">சிறிய தொடர் செலவுகள் உங்களை காலி செய்யும் முன் அவற்றைக் கட்டுப்படுத்துங்கள்.</string>
